{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "whatsapp": { "type": "string", "description": "User's WhatsApp number" },
        "credits": { "type": "integer", "description": "Number of search credits remaining" },
        "lastCreditRefresh": { "type": "string", "description": "Last date (YYYY-MM-DD) credits were refreshed" },
        "subscription": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["none", "3days", "7days"] },
            "expiresAt": { "type": "string", "format": "date-time" }
          },
          "description": "Active subscription details"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "resumes": {
      "title": "Resume",
      "description": "Saved resume data",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner's UID" },
        "title": { "type": "string", "description": "Resume title/name" },
        "data": { "type": "object", "description": "The complete resume data object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "data"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/resumes/{resumeId}": {
      "schema": "resumes",
      "description": "User saved resumes"
    }
  }
}
